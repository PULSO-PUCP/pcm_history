\newlabel{tab:cox_models}{{8}{24}{Cox Proportional Hazards Models of Ministerial Exit}{table.caption.11}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.3}Do Some Portfolios Systematically Escape the Dominant Pattern?}{25}{subsection.4.3}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Kaplan--Meier Survival Curves by Portfolio. Each curve shows the estimated probability that a minister remains in office over time, pooling all institutional epochs within each portfolio. Log-rank test: $\chi ^2$ = 21.1, df = 4, $p$ = 0.0003. \textit  {Source}: Author's calculations based on original ministerial-spell database, 1821--2026.}}{26}{figure.caption.12}\protected@file@percent }
\newlabel{fig:km_portfolio}{{3}{26}{Kaplan--Meier Survival Curves by Portfolio. Each curve shows the estimated probability that a minister remains in office over time, pooling all institutional epochs within each portfolio. Log-rank test: $\chi ^2$ = 21.1, df = 4, $p$ = 0.0003. \textit {Source}: Author's calculations based on original ministerial-spell database, 1821--2026}{figure.caption.12}{}}
\@writefile{lot}{\contentsline {table}{\numberline {9}{\ignorespaces Log-Rank Test of Survival Differences Across Portfolios}}{26}{table.caption.13}\protected@file@percent }
\newlabel{tab:logrank_portfolio}{{9}{26}{Log-Rank Test of Survival Differences Across Portfolios}{table.caption.13}{}}
\@writefile{lot}{\contentsline {table}{\numberline {10}{\ignorespaces Cox Model 4: Economy Portfolio Effects by Epoch (Protective Belt Test)}}{27}{table.caption.15}\protected@file@percent }
\newlabel{tab:cox_belt}{{10}{27}{Cox Model 4: Economy Portfolio Effects by Epoch (Protective Belt Test)}{table.caption.15}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces Kaplan--Meier Survival Curves: Economy vs.\ Interior by Institutional Epoch. Each panel compares ministerial survival in the Economy and Interior portfolios within the same epoch. Divergence between curves within a panel indicates epoch-specific portfolio effects. The Economy portfolio shows no survival advantage in the four earlier epochs but diverges markedly from Interior in the Democracy without Parties epoch, consistent with the protective belt argument. \textit  {Source}: Author's calculations based on original ministerial-spell database, 1821--2026.}}{28}{figure.caption.14}\protected@file@percent }
\newlabel{fig:km_belt}{{4}{28}{Kaplan--Meier Survival Curves: Economy vs.\ Interior by Institutional Epoch. Each panel compares ministerial survival in the Economy and Interior portfolios within the same epoch. Divergence between curves within a panel indicates epoch-specific portfolio effects. The Economy portfolio shows no survival advantage in the four earlier epochs but diverges markedly from Interior in the Democracy without Parties epoch, consistent with the protective belt argument. \textit {Source}: Author's calculations based on original ministerial-spell database, 1821--2026}{figure.caption.14}{}}
