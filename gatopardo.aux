\@writefile{toc}{\contentsline {subsection}{\numberline {4.2}Have Peru's Critical Junctures Generated Different Continuity Conditions?}{21}{subsection.4.2}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Kaplan--Meier Survival Curves by Institutional Epoch. Each curve shows the estimated probability that a minister remains in office over time, pooling all five portfolios (Premier, Economy, Interior, Education, and Health) within each epoch. Curves that remain elevated represent epochs with more favorable continuity conditions; curves that fall steeply in the early months indicate epochs in which ministerial replacement was rapid and routine --- the observable signature of the escape valve operating at full force. Log-rank test: $\chi ^2$ = 82.3, df = 4, $p$ $<$ 0.001. \textit  {Source}: Author's calculations based on original ministerial-spell database, 1821--2026.}}{22}{figure.caption.9}\protected@file@percent }
\newlabel{fig:km_epoch}{{2}{22}{Kaplan--Meier Survival Curves by Institutional Epoch. Each curve shows the estimated probability that a minister remains in office over time, pooling all five portfolios (Premier, Economy, Interior, Education, and Health) within each epoch. Curves that remain elevated represent epochs with more favorable continuity conditions; curves that fall steeply in the early months indicate epochs in which ministerial replacement was rapid and routine --- the observable signature of the escape valve operating at full force. Log-rank test: $\chi ^2$ = 82.3, df = 4, $p$ $<$ 0.001. \textit {Source}: Author's calculations based on original ministerial-spell database, 1821--2026}{figure.caption.9}{}}
\@writefile{lot}{\contentsline {table}{\numberline {7}{\ignorespaces Log-Rank Test of Survival Differences Across Institutional Epochs}}{23}{table.caption.10}\protected@file@percent }
\newlabel{tab:logrank_epoch}{{7}{23}{Log-Rank Test of Survival Differences Across Institutional Epochs}{table.caption.10}{}}
