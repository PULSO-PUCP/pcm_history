library(survival)
library(dplyr)
library(broom)
library(knitr)
library(kableExtra)
datos_all <- gatopardo |>
filter(portfolio %in% c("MEF","PCM","Interior","Educacion","Salud")) |>
mutate(
portfolio = factor(
portfolio,
levels = c("MEF","PCM","Interior","Educacion","Salud")
),
globalization_period = factor(
ifelse(year < 2001,
"1821--2000",
"2001--Present"),
levels=c("1821--2000","2001--Present")
),
President = factor(President)
)
fit <- coxph(
Surv(duration,event)~
portfolio*globalization_period+
frailty(President),
data=datos_all
)
tab <- tidy(
fit,
exponentiate=TRUE,
conf.int=TRUE
)
tab <- tab |>
filter(
grepl("^portfolio",term)
) |>
mutate(
Portfolio=gsub("^portfolio","",term)
) |>
select(
Portfolio,
estimate,
conf.low,
conf.high,
p.value
) |>
mutate(
`Hazard ratio`=sprintf("%.2f",estimate),
`95\\% CI`=sprintf("[%.2f, %.2f]",conf.low,conf.high),
`p-value`=format.pval(p.value,digits=3,eps=.001)
) |>
select(
Portfolio,
`Hazard ratio`,
`95\\% CI`,
`p-value`
)
tab |>
kbl(
format="latex",
booktabs=TRUE,
caption="Ministerial Replacement Relative to the MEF (1821--2000)",
label="cox_all_portfolios_global",
escape=FALSE
) |>
kable_styling(
latex_options="hold_position",
font_size=9
) |>
footnote(
general=paste(
"Hazard ratios are estimated relative to the Ministry of Economy and Finance (MEF).",
"Values above one indicate a greater hazard of ministerial replacement than the MEF.",
"The model includes portfolio, globalization period, their interaction, and a shared frailty term for presidential administration."
),
threeparttable=TRUE,
escape=FALSE
)
library(survival)
library(dplyr)
library(purrr)
library(tibble)
library(knitr)
library(kableExtra)
datos_all <- gatopardo |>
filter(portfolio %in% c("MEF", "PCM", "Interior", "Educacion", "Salud")) |>
mutate(
portfolio = factor(
as.character(portfolio),
levels = c("MEF", "PCM", "Interior", "Educacion", "Salud")
),
globalization_period = factor(
ifelse(year < 2001, "1821--2000", "2001--Present"),
levels = c("1821--2000", "2001--Present")
),
President = factor(as.character(President))
)
fit_all <- coxph(
Surv(duration, event) ~
portfolio * globalization_period +
frailty(President),
data = datos_all
)
b <- coef(fit_all)
V <- vcov(fit_all)
coef_names <- names(b)
get_portfolio_contrast <- function(port, period) {
L <- setNames(rep(0, length(b)), coef_names)
# Portfolio contrast against MEF in baseline period
port_term <- paste0("portfolio", port)
if (port_term %in% coef_names) {
L[port_term] <- 1
}
# Add interaction for post-2001 period
if (period == "2001--Present") {
int1 <- paste0("portfolio", port, ":globalization_period", period)
int2 <- paste0("globalization_period", period, ":portfolio", port)
if (int1 %in% coef_names) {
L[int1] <- 1
} else if (int2 %in% coef_names) {
L[int2] <- 1
}
}
log_hr <- sum(L * b)
se <- sqrt(as.numeric(t(L) %*% V %*% L))
z <- log_hr / se
tibble(
Portfolio = recode(
port,
"Educacion" = "Education",
"Salud" = "Health"
),
Period = period,
HR = exp(log_hr),
CI_low = exp(log_hr - 1.96 * se),
CI_high = exp(log_hr + 1.96 * se),
p_value = 2 * pnorm(abs(z), lower.tail = FALSE)
)
}
tab_all <- expand.grid(
Portfolio = c("PCM", "Interior", "Educacion", "Salud"),
Period = c("1821--2000", "2001--Present"),
stringsAsFactors = FALSE
) |>
pmap_dfr(~ get_portfolio_contrast(..1, ..2)) |>
mutate(
`Hazard ratio` = sprintf("%.2f", HR),
`95\\% CI` = sprintf("[%.2f, %.2f]", CI_low, CI_high),
`p-value` = format.pval(p_value, digits = 3, eps = .001)
) |>
select(
Period,
Portfolio,
`Hazard ratio`,
`95\\% CI`,
`p-value`
)
tab_all |>
kbl(
format = "latex",
booktabs = TRUE,
align = c("l", "l", "c", "c", "c"),
caption = "Ministerial Replacement Relative to the MEF before and after Globalization Consolidation",
label = "cox_all_portfolios_global",
escape = FALSE
) |>
kable_styling(
latex_options = c("hold_position"),
font_size = 9
) |>
footnote(
general = paste(
"Hazard ratios compare each portfolio to the Ministry of Economy and Finance (MEF) within each period.",
"Values above one indicate a greater hazard of ministerial replacement than the MEF.",
"Estimates are derived from a single Cox proportional hazards model including portfolio, globalization period, their interaction, and a shared frailty term for presidential administration.",
"Reported p-values correspond to pre-specified within-period portfolio contrasts relative to the MEF."
),
threeparttable = TRUE,
escape = FALSE
)
