library(survival)
library(survminer)
library(dplyr)
library(ggplot2)
datos_pcm_mef <- gatopardo |>
filter(portfolio %in% c("PCM", "MEF"))
km_epoch <- survfit(
Surv(duration, event) ~ political_framework,
data = datos_pcm_mef
)
s <- surv_summary(km_epoch) |>
mutate(
epoch = gsub("^political_framework=", "", strata)
)
meds <- s |>
group_by(epoch) |>
slice_min(order_by = abs(surv - 0.5), n = 1, with_ties = FALSE) |>
ungroup()
ann_df <- meds |>
mutate(
num = as.numeric(gsub("^([0-9]+).*", "\\1", political_framework)),
ord = match(num, c(1, 2, 6, 5, 3, 4))
) |>
arrange(ord) |>
mutate(
x_text = c(230, 360, 500, 640, 780, 920),
y_text = c(.545, .550, .555, .560, .565, .570),
label = as.character(num)
)
ggplot(
s,
aes(
x = time,
y = surv,
colour = as.ordered(political_framework),
linetype = political_framework
)
) +
geom_step(linewidth = 1.5) +
geom_hline(
yintercept = 0.5,
linetype = "dashed",
colour = "grey50",
alpha = 0.6
) +
geom_point(
data = ann_df,
aes(x = time, y = 0.5),
inherit.aes = FALSE,
colour = "grey30",
size = 0
) +
geom_segment(
data = ann_df,
aes(x = x_text, y = y_text, xend = time, yend = 0.5),
inherit.aes = FALSE,
colour = "grey40",
linewidth = 0.35
) +
geom_label(
data = ann_df,
aes(x = x_text, y = y_text, label = label),
inherit.aes = FALSE,
hjust = 0.5,
vjust = 0.5,
size = 3.5,
colour = "grey20",
fill = "white",
label.size = 0.25,
fontface = "bold"
)+
labs(
x = "Ministerial duration in days",
y = "Survival probability",
colour = NULL,
linetype = NULL
) +
scale_color_brewer(type = "div", palette = "Spectral") +
theme_classic2() +
theme(
legend.position = c(.75, .75),
legend.background = element_rect(
fill = "white",
colour = "grey60"
),
legend.key = element_blank()
) + annotate(
"text",
x = 1750,
y = .51,
label = "Median survival (S = 0.5)",
hjust = 1,
size = 3,
colour = "grey20"
)
