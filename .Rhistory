library(dplyr)
library(survival)
library(knitr)
datos_pcm_mef <- gatopardo |>
filter(cartera %in% c("PCM", "MEF"))
cox_epoch <- coxph(
Surv(duration, event) ~ epoch,
data = datos_pcm_mef
)
cox_table <- summary(cox_epoch)
cox_results <- data.frame(
Epoch = rownames(cox_table$coefficients),
Hazard_Ratio = cox_table$coefficients[, "exp(coef)"],
CI_Lower = cox_table$conf.int[, "lower .95"],
CI_Upper = cox_table$conf.int[, "upper .95"],
p_value = cox_table$coefficients[, "Pr(>|z|)"]
) |>
mutate(
Epoch = gsub("^epoch", "", Epoch),
Hazard_Ratio = round(Hazard_Ratio, 2),
CI = paste0(
round(CI_Lower, 2),
"--",
round(CI_Upper, 2)
),
p_value = ifelse(p_value < .001, "< .001", round(p_value, 3))
) |>
select(
Epoch,
Hazard_Ratio,
CI,
p_value
)
cox_results |>
kable(
caption = "Cox Proportional Hazards Model of Ministerial Replacement by Institutional Epoch\\label{tab:cox_epoch}",
booktabs = TRUE,
format = "latex",
col.names = c(
"Institutional Epoch",
"Hazard Ratio",
"95\\% CI",
"p-value"
),
linesep = ""
)
summary(cox_epoch)
cox_results |>
kable(
caption = "Cox Proportional Hazards Model of Ministerial Replacement by Institutional Epoch\\label{tab:cox_epoch}",
booktabs = TRUE,
format = "latex",
col.names = c(
"Institutional Epoch",
"Hazard Ratio",
"95\\% CI",
"p-value"
),
linesep = ""
)
<<cox_epoch_fit, echo=FALSE, results=tex, message=FALSE, warning=FALSE>>=
fit_table <- data.frame(
Model = "Cox proportional hazards",
N = cox_epoch$n,
Events = cox_epoch$nevent,
LR_Chisq = round(cox_table$logtest["test"], 2),
df = cox_table$logtest["df"],
p_value = ifelse(
cox_table$logtest["pvalue"] < .001,
"< .001",
round(cox_table$logtest["pvalue"], 3)
)
)
fit_table |>
kable(
caption = "Model Fit for Cox Model of Institutional Epochs\\label{tab:cox_epoch_fit}",
booktabs = TRUE,
format = "latex",
col.names = c("Model", "N", "Events", "LR Chisq", "df", "p-value"),
linesep = ""
)
<<cox_epoch, echo=FALSE, results=tex, message=FALSE, warning=FALSE>>=
library(dplyr)
library(survival)
library(knitr)
datos_pcm_mef <- gatopardo |>
filter(cartera %in% c("PCM", "MEF")) |>
mutate(
epoch_model = factor(
as.character(epoch),
levels = c(
"5. Democracy without Parties",
"1. State Formation",
"2. Oligarchic State",
"3. Power-Sharing State",
"4. Transition and Crisis",
"6. Current Critical Juncture"
)
)
)
cox_epoch <- coxph(
Surv(duration, event) ~ epoch_model,
data = datos_pcm_mef
)
cox_table <- summary(cox_epoch)
cox_results <- data.frame(
Epoch = rownames(cox_table$coefficients),
Hazard_Ratio = cox_table$coefficients[, "exp(coef)"],
CI_Lower = cox_table$conf.int[, "lower .95"],
CI_Upper = cox_table$conf.int[, "upper .95"],
p_value = cox_table$coefficients[, "Pr(>|z|)"]
) |>
mutate(
Epoch = gsub("^epoch_model", "", Epoch),
Hazard_Ratio = round(Hazard_Ratio, 2),
CI = paste0(round(CI_Lower, 2), "--", round(CI_Upper, 2)),
p_value = ifelse(p_value < .001, "< .001", round(p_value, 3))
) |>
select(Epoch, Hazard_Ratio, CI, p_value)
cox_results |>
kable(
caption = "Cox Proportional Hazards Model of Ministerial Replacement by Institutional Epoch\\label{tab:cox_epoch}",
booktabs = TRUE,
format = "latex",
col.names = c(
"Institutional Epoch",
"Hazard Ratio",
"95\\% CI",
"p-value"
),
linesep = ""
)
cox_table
cox_results
library(dplyr)
library(survival)
library(knitr)
datos_pcm_mef <- gatopardo |>
filter(cartera %in% c("PCM", "MEF")) |>
mutate(
epoch_model = factor(
as.character(epoch),
levels = c(
"5. Democracy without Parties",
"1. State Formation",
"2. Oligarchic State",
"3. Power-Sharing State",
"4. Transition and Crisis",
"6. Current Critical Juncture"
)
)
)
cox_epoch <- coxph(
Surv(duration, event) ~ epoch_model,
data = datos_pcm_mef
)
cox_table <- summary(cox_epoch)
cox_results <- data.frame(
Epoch = rownames(cox_table$coefficients),
Hazard_Ratio = cox_table$coefficients[, "exp(coef)"],
CI_Lower = cox_table$conf.int[, "lower .95"],
CI_Upper = cox_table$conf.int[, "upper .95"],
p_value = cox_table$coefficients[, "Pr(>|z|)"]
) |>
mutate(
Epoch = gsub("^epoch_model", "", Epoch),
Hazard_Ratio = round(Hazard_Ratio, 2),
CI = paste0(round(CI_Lower, 2), "--", round(CI_Upper, 2)),
p_value = ifelse(p_value < .001, "< .001", round(p_value, 3))
) |>
select(Epoch, Hazard_Ratio, CI, p_value)
cox_results |>
kable(
caption = "Cox Proportional Hazards Model of Ministerial Replacement by Institutional Epoch\\label{tab:cox_epoch}",
booktabs = TRUE,
format = "latex",
escape = FALSE,
row.names = FALSE,
col.names = c(
"Institutional Epoch",
"Hazard Ratio",
"95\\% CI",
"p-value"
),
linesep = ""
)
