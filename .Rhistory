)
) +
geom_step(linewidth=.9) +
facet_wrap(~cartera) +
labs(
x = "Ministerial duration in days",
y = "Survival probability",
colour = NULL,
linetype = NULL
) +
theme_minimal() +scale_x_log10() + scale_color_brewer()
library(survival)
library(survminer)
library(dplyr)
datos_pcm_mef <- gatopardo |>
filter(cartera %in% c("PCM","MEF"))
km_epoch_port <- survfit(
Surv(duration, event) ~ epoch + cartera,
data = datos_pcm_mef
)
s <- surv_summary(km_epoch_port)
s <- s |>
tidyr::separate(
strata,
into = c("epoch","cartera"),
sep = ", "
) |>
mutate(
epoch   = gsub("^epoch=", "", epoch),
cartera = gsub("^cartera=", "", cartera)
)
ggplot(
s,
aes(
x = time,
y = surv,
colour = as.ordered(epoch),
linetype = epoch
)
) +
geom_step(linewidth=.9) +
facet_wrap(~cartera) +
labs(
x = "Ministerial duration in days",
y = "Survival probability",
colour = NULL,
linetype = NULL
) +
theme_minimal() +scale_x_log10() + scale_color_brewer(type = 'seq')
