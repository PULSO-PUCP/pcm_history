library(dplyr)
library(survival)
library(knitr)
datos_pcm_mef <- gatopardo |>
filter(cartera %in% c("PCM", "MEF"))
logrank_epoch <- survdiff(
Surv(duration, event) ~ epoch,
data = datos_pcm_mef
)
logrank_table <- data.frame(
Test = "Log-rank test",
Chisq = unname(logrank_epoch$chisq),
df = length(logrank_epoch$n) - 1,
p_value = pchisq(
logrank_epoch$chisq,
df = length(logrank_epoch$n) - 1,
lower.tail = FALSE
)
)
logrank_table |>
mutate(
Chisq = round(Chisq, 2),
p_value = ifelse(p_value < .001, "< .001", round(p_value, 3))
) |>
kable(
caption = "Log-Rank Test of Ministerial Survival Across Institutional Epochs\\label{tab:logrank_epoch}",
booktabs = TRUE,
format = "latex",
linesep = ""
)
