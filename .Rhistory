aes(
xmin = low,
xmax = high
),
height = .12,
linewidth = .7
) +
geom_point(size = 3) +
geom_text(
aes(
label = sprintf("%.2f", HR)
),
nudge_y = .16,
size = 3.5
) +
scale_x_log10(
breaks = c(0.5,0.75,1,1.5,2),
labels = c("0.5","0.75","1","1.5","2")
) +
labs(
x = "Hazard ratio (PCM relative to MEF)",
y = NULL
) +
theme_classic2() +
theme(
axis.text.y = element_text(size = 10)
)
library(survival)
library(dplyr)
library(broom)
library(knitr)
library(kableExtra)
datos_all_pb <- gatopardo |>
filter(portfolio %in% c("MEF","PCM","Interior","Educacion","Salud")) |>
mutate(
portfolio = recode(
portfolio,
Educacion = "Education",
Salud      = "Health"
),
portfolio = factor(
portfolio,
levels = c("MEF","PCM","Interior","Education","Health")
),
pb_period = factor(
ifelse(year < 2001, "Before 2001", "2001 onward"),
levels = c("Before 2001","2001 onward")
)
)
fit_all_pb <- coxph(
Surv(duration, event) ~ portfolio * pb_period,
data = datos_all_pb
)
tab_all_pb <- tidy(
fit_all_pb,
exponentiate = TRUE,
conf.int = TRUE
) |>
mutate(
term = case_when(
term == "portfolioPCM" ~ "PCM vs. MEF before 2001",
term == "portfolioInterior" ~ "Interior vs. MEF before 2001",
term == "portfolioEducation" ~ "Education vs. MEF before 2001",
term == "portfolioHealth" ~ "Health vs. MEF before 2001",
term == "pb_period2001 onward" ~
"MEF after 2001 vs. MEF before 2001",
term == "portfolioPCM:pb_period2001 onward" ~
"Additional PCM--MEF difference after 2001",
term == "portfolioInterior:pb_period2001 onward" ~
"Additional Interior--MEF difference after 2001",
term == "portfolioEducation:pb_period2001 onward" ~
"Additional Education--MEF difference after 2001",
term == "portfolioHealth:pb_period2001 onward" ~
"Additional Health--MEF difference after 2001",
TRUE ~ term
),
HR = sprintf("%.2f", estimate),
CI = sprintf("[%.2f, %.2f]", conf.low, conf.high),
p = ifelse(p.value < .001, "< .001",
sprintf("%.3f", p.value))
) |>
select(
Contrast = term,
`Hazard ratio` = HR,
`95\\% CI` = CI,
`p-value` = p
)
tab_all_pb |>
kbl(
format = "latex",
booktabs = TRUE,
align = c("l","c","c","c"),
caption = "Ministerial replacement relative to the MEF before and after Protective Belt consolidation",
label = "cox_all_portfolios_pb",
escape = FALSE
) |>
kable_styling(
latex_options = c("hold_position","scale_down"),
font_size = 8
) |>
footnote(
general = paste(
"Hazard ratios are estimated from a Cox proportional hazards model",
"including an interaction between governmental organization and",
"Protective Belt period.",
"The MEF before 2001 is the reference category.",
"Interaction terms report the additional difference relative to the MEF",
"after 2001."
),
threeparttable = TRUE,
escape = FALSE
)
