y = duration)) +
geom_boxplot(width = 0.3,
outlier.alpha = 0.35) +
# Median
geom_text(
data = labs,
aes(y = Median,
label = paste0(round(Median, 1))),
nudge_x = 0.18,
hjust = 0,
size = 3.2,
color = "gray40"
) +
# First quartile
geom_text(
data = labs,
aes(y = Q1,
label = paste0(round(Q1, 1))),
nudge_x = 0.18,
hjust = 0,
size = 2.8,
color = "gray40"
) +
# Third quartile
geom_text(
data = labs,
aes(y = Q3,
label = paste0(round(Q3, 1))),
nudge_x = 0.18,
hjust = 0,
size = 2.8,
color = "gray40"
) +
# Sample size
geom_text(
data = labs,
aes(y = 1300,
label = paste0("N = ", N)),
fontface = "bold",
size = 3.2
) +
coord_cartesian(clip = "off") +
labs(
x = NULL,
y = "Duration (days)"
) +
theme_classic2()  +
theme(
axis.text.x = element_text(angle = 30, hjust = 1),
plot.margin = margin(5.5, 50, 5.5, 5.5)
) #+ scale_y_log10()
