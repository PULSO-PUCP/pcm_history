library(survival)
library(dplyr)
library(broom)
library(ggplot2)
library(forcats)
datos_all_pb <- gatopardo |>
filter(portfolio %in% c("MEF","PCM","Interior","Educacion","Salud")) |>
mutate(
portfolio = recode(
as.character(portfolio),
Educacion = "Education",
Salud = "Health"
),
portfolio = factor(
portfolio,
levels = c("MEF","PCM","Interior","Education","Health")
),
pb_period = factor(
ifelse(year < 2001,
"a. Before 2001",
"b. 2001 onward"),
levels = c("a. Before 2001","b. 2001 onward")
)
)
plot_df <-
bind_rows(
lapply(levels(datos_all_pb$pb_period), function(period_i){
fit_i <-
coxph(
Surv(duration,event) ~ relevel(portfolio,"MEF"),
data = filter(datos_all_pb,
pb_period==period_i)
)
tidy(
fit_i,
exponentiate=TRUE,
conf.int=TRUE
) |>
filter(grepl("^relevel",term)) |>
mutate(
pb_period = period_i,
portfolio = sub("relevel\\(portfolio, \"MEF\"\\)","",term),
label = sprintf("%.2f",estimate)
)
})
) |>
mutate(
portfolio=factor(
portfolio,
levels=c("PCM","Interior","Education","Health")
)
)
ggplot(
plot_df,
aes(
x=estimate,
y=fct_rev(portfolio)
)
)+
geom_vline(
xintercept=1,
linetype=2,
colour="grey35",
linewidth=.6
)+
geom_errorbarh(
aes(
xmin=conf.low,
xmax=conf.high
),
height=.16,
linewidth=.6
)+
geom_point(size=2.6)+
geom_text(
aes(
label=label
),
nudge_y=.18,
size=3
)+
facet_wrap(
~pb_period,
ncol=2
)+
scale_x_log10()+
labs(
x="Hazard ratio relative to the MEF",
y=NULL
)+
theme_classic2()+
theme(
legend.position="none",
strip.background=
element_rect(
fill="white",
colour="grey70"
),
strip.text=
element_text(
face="bold"
),
axis.text.y=
element_text(size=10)
)
