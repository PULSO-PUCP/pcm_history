@book{dargent_technocracy_2014,
	edition = {1},
	title = {Technocracy and {Democracy} in {Latin} {America}: {The} {Experts} {Running} {Government}},
	copyright = {https://www.cambridge.org/core/terms},
	isbn = {978-1-107-44666-3 978-1-107-05987-0 978-1-107-66852-2},
	shorttitle = {Technocracy and {Democracy} in {Latin} {America}},
	url = {https://www.cambridge.org/core/product/identifier/9781107446663/type/book},
	doi = {10.1017/CBO9781107446663},
	abstract = {Praised by some as islands of efficiency in a sea of unprofessional, politicized and corrupt states, and criticized by others for removing wide areas of policy making from the democratic arena, technocrats have become prominent and controversial actors in Latin American politics. Nonelected state officials with advanced educations from top universities, technocrats achieve considerable autonomy from political and economic actors and exert great influence over their countries\&apos; fates. This finding poses an intriguing paradox. These experts lack an independent base of authority, such as popular election, and the tenure enjoyed by professional bureaucrats. What, then, explains the power of technocrats in democratic Latin America? Why do they enjoy and maintain greater policy influence in some areas than in others? Through analysis of economic and health policy in Colombia from 1958 to 2011 and in Peru from 1980 to 2011, Technocracy and Democracy in Latin America answers these and other questions about experts in Latin America.},
	urldate = {2025-05-08},
	publisher = {Cambridge University Press},
	author = {Dargent, Eduardo},
	month = nov,
	year = {2014},
}

